    <script>
        // ==================== CONFIGURACIÓN GLOBAL ====================
        
        // Datos por defecto
        const DEFAULT_CONFIG = {
            prices: {
                '1-50': 6000,
                '51-100': 8000,
                '101-200': 10000,
                '201-300': 13000,
                '300+': 16000
            },
            extras: [
                { id: 'iluminacion', name: 'Iluminación Profesional Extra', description: 'Cabezas móviles, láser, máquina de humo', price: 1500, active: true },
                { id: 'pantalla', name: 'Pantalla LED Gigante', description: 'Proyección de videos y fotos', price: 2000, active: true },
                { id: 'hora-extra', name: 'Hora Extra de Servicio', description: 'Extensión más allá del tiempo contratado', price: 1200, active: true },
                { id: 'ceremonia', name: 'Música para Ceremonia', description: 'Amplificación para ceremonia civil/religiosa', price: 1800, active: true },
                { id: 'video', name: 'Video del Evento', description: 'Edición profesional de los mejores momentos', price: 3500, active: true }
            ],
            content: {
                heroTitle: 'Transforma tu Evento',
                heroSubtitle: 'en una Experiencia Inolvidable',
                description: 'Más de 500 eventos exitosos. La combinación perfecta de voz, música y animación que tu celebración merece.',
                phone: '7228077264',
                urgency: 'Solo quedan 4 fechas disponibles para diciembre 2026',
                facebook: 'https://www.facebook.com/share/1C92LXi5wP/'
            },
            blockedDates: [], // Fechas bloqueadas
            bookings: [],
            password: 'sergio2026',
            gallery: [] // Galería de imágenes en base64
        };

        // Estado actual
        let config = {};
        let currentAdminDate = new Date();
        let currentPublicDate = new Date();
        let selectedAdminDate = null;

        // ==================== INICIALIZACIÓN ====================

        function init() {
            // Cargar configuración guardada o usar defaults
            const saved = localStorage.getItem('sve_config');
            config = saved ? JSON.parse(saved) : { ...DEFAULT_CONFIG };
            
            // Asegurar que todas las propiedades existan
            config.prices = config.prices || DEFAULT_CONFIG.prices;
            config.extras = config.extras || DEFAULT_CONFIG.extras;
            config.content = config.content || DEFAULT_CONFIG.content;
            config.blockedDates = config.blockedDates || [];
            config.bookings = config.bookings || [];
            config.gallery = config.gallery || [];
            
            updateStats();
            // Iniciar en modo público
            renderPublicCalendar();
            updatePublicPrice();
            renderPublicGallery();
        }

        // ==================== NAVEGACIÓN ENTRE MODOS ====================

        function showAdminLogin() {
            document.getElementById('public-site').classList.add('hidden');
            document.getElementById('admin-mode').classList.remove('hidden');
            document.getElementById('login-screen').classList.remove('hidden');
            document.getElementById('admin-dashboard').classList.add('hidden');
            document.getElementById('admin-password').value = '';
            document.getElementById('admin-password').focus();
        }

        function backToPublic() {
            document.getElementById('admin-mode').classList.add('hidden');
            document.getElementById('public-site').classList.remove('hidden');
            renderPublicCalendar();
            renderPublicGallery();
        }

        // ==================== AUTHENTICACIÓN ====================

        function login() {
            const pass = document.getElementById('admin-password').value;
            if (pass === config.password) {
                document.getElementById('login-screen').classList.add('hidden');
                document.getElementById('admin-dashboard').classList.remove('hidden');
                showTab('prices');
                loadPrices();
                loadExtras();
                loadContent();
                renderAdminCalendar();
                loadBookings();
                renderAdminGallery();
            } else {
                alert('Contraseña incorrecta');
            }
        }

        function logout() {
            document.getElementById('admin-dashboard').classList.add('hidden');
            document.getElementById('login-screen').classList.remove('hidden');
            document.getElementById('admin-password').value = '';
        }

        // ==================== NAVEGACIÓN TABS ====================

        function showTab(tabName) {
            // Ocultar todos los tabs
            document.querySelectorAll('.tab-content').forEach(tab => tab.classList.add('hidden'));
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active', 'bg-yellow-500', 'text-black'));
            
            // Mostrar tab seleccionado
            document.getElementById(`tab-${tabName}`).classList.remove('hidden');
            document.querySelector(`[data-tab="${tabName}"]`).classList.add('active', 'bg-yellow-500', 'text-black');
            
            // Acciones específicas por tab
            if (tabName === 'calendar') renderAdminCalendar();
            if (tabName === 'bookings') loadBookings();
            if (tabName === 'gallery') renderAdminGallery();
        }

        // ==================== GESTIÓN DE PRECIOS ====================

        function loadPrices() {
            document.getElementById('price-1-50').value = config.prices['1-50'];
            document.getElementById('price-51-100').value = config.prices['51-100'];
            document.getElementById('price-101-200').value = config.prices['101-200'];
            document.getElementById('price-201-300').value = config.prices['201-300'];
            document.getElementById('price-300').value = config.prices['300+'];
            updatePricePreview();
        }

        function updatePricePreview() {
            const preview = document.getElementById('price-preview');
            const prices = [
                { range: '1-50', price: document.getElementById('price-1-50').value },
                { range: '51-100', price: document.getElementById('price-51-100').value },
                { range: '101-200', price: document.getElementById('price-101-200').value },
                { range: '201-300', price: document.getElementById('price-201-300').value },
                { range: '300+', price: document.getElementById('price-300').value }
            ];
            
            preview.innerHTML = prices.map(p => `
                <div class="bg-black/30 rounded-lg p-4 border border-yellow-500/20">
                    <div class="text-gray-400 text-sm mb-1">${p.range} invitados</div>
                    <div class="text-2xl font-bold gold-gradient">$${parseInt(p.price).toLocaleString()}</div>
                </div>
            `).join('');
        }

        function savePrices() {
            config.prices = {
                '1-50': parseInt(document.getElementById('price-1-50').value) || 6000,
                '51-100': parseInt(document.getElementById('price-51-100').value) || 8000,
                '101-200': parseInt(document.getElementById('price-101-200').value) || 10000,
                '201-300': parseInt(document.getElementById('price-201-300').value) || 13000,
                '300+': parseInt(document.getElementById('price-300').value) || 16000
            };
            saveConfig();
            alert('Precios guardados correctamente');
            updatePricePreview();
        }

        function resetPrices() {
            if (confirm('¿Restaurar precios por defecto?')) {
                config.prices = { ...DEFAULT_CONFIG.prices };
                loadPrices();
                saveConfig();
            }
        }

        // ==================== GESTIÓN DE EXTRAS ====================

        function loadExtras() {
            const container = document.getElementById('extras-list');
            container.innerHTML = config.extras.map((extra, index) => `
                <div class="bg-black/30 rounded-xl p-4 border border-yellow-500/20">
                    <div class="flex items-center gap-4 mb-3">
                        <div class="flex-1">
                            <input type="text" value="${extra.name}" 
                                   onchange="updateExtra(${index}, 'name', this.value)"
                                   class="input-premium w-full px-3 py-2 rounded-lg text-white font-semibold" placeholder="Nombre del servicio">
                        </div>
                        <div class="w-32">
                            <div class="relative">
                                <span class="absolute left-3 top-2.5 text-gray-400">$</span>
                                <input type="number" value="${extra.price}" 
                                       onchange="updateExtra(${index}, 'price', this.value)"
                                       class="input-premium w-full pl-6 pr-3 py-2 rounded-lg text-yellow-400 font-bold">
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            <div class="toggle-switch ${extra.active ? 'active' : ''}" onclick="toggleExtra(${index})"></div>
                            <button onclick="removeExtra(${index})" class="text-red-400 hover:text-red-300 p-2">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                    <textarea onchange="updateExtra(${index}, 'description', this.value)"
                              class="input-premium w-full px-3 py-2 rounded-lg text-sm text-gray-300" 
                              rows="2" placeholder="Descripción del servicio">${extra.description}</textarea>
                </div>
            `).join('');
        }

        function updateExtra(index, field, value) {
            if (field === 'price') value = parseInt(value) || 0;
            config.extras[index][field] = value;
        }

        function toggleExtra(index) {
            config.extras[index].active = !config.extras[index].active;
            loadExtras();
        }

        function removeExtra(index) {
            if (confirm('¿Eliminar este servicio?')) {
                config.extras.splice(index, 1);
                loadExtras();
            }
        }

        function addNewExtra() {
            config.extras.push({
                id: 'extra_' + Date.now(),
                name: 'Nuevo Servicio',
                description: 'Descripción del servicio',
                price: 1000,
                active: true
            });
            loadExtras();
        }

        function saveExtras() {
            saveConfig();
            alert('Servicios adicionales guardados');
        }

        // ==================== GESTIÓN DE CONTENIDO ====================

        function loadContent() {
            document.getElementById('content-hero-title').value = config.content.heroTitle;
            document.getElementById('content-hero-subtitle').value = config.content.heroSubtitle;
            document.getElementById('content-description').value = config.content.description;
            document.getElementById('content-phone').value = config.content.phone;
            document.getElementById('content-urgency').value = config.content.urgency;
            document.getElementById('content-facebook').value = config.content.facebook || 'https://www.facebook.com/share/1C92LXi5wP/';
        }

        function saveContent() {
            config.content = {
                heroTitle: document.getElementById('content-hero-title').value,
                heroSubtitle: document.getElementById('content-hero-subtitle').value,
                description: document.getElementById('content-description').value,
                phone: document.getElementById('content-phone').value,
                urgency: document.getElementById('content-urgency').value,
                facebook: document.getElementById('content-facebook').value
            };
            saveConfig();
            alert('Contenido actualizado');
        }

        // ==================== CALENDARIO ADMIN ====================

        function renderAdminCalendar() {
            const year = currentAdminDate.getFullYear();
            const month = currentAdminDate.getMonth();
            const firstDay = new Date(year, month, 1).getDay();
            const daysInMonth = new Date(year, month + 1, 0).getDate();
            
            document.getElementById('admin-current-month').textContent = 
                new Date(year, month).toLocaleDateString('es-ES', { month: 'long', year: 'numeric' });
            
            const grid = document.getElementById('admin-calendar-grid');
            grid.innerHTML = '';
            
            // Espacios vacíos
            for (let i = 0; i < firstDay; i++) {
                grid.appendChild(document.createElement('div'));
            }
            
            // Días
            for (let day = 1; day <= daysInMonth; day++) {
                const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
                const date = new Date(year, month, day);
                const isBlocked = config.blockedDates.includes(dateStr);
                const hasBooking = config.bookings.some(b => b.date === dateStr);
                
                const dayEl = document.createElement('div');
                dayEl.className = `calendar-day ${isBlocked ? 'disabled' : ''} ${hasBooking ? 'bg-yellow-500/20' : ''}`;
                dayEl.textContent = day;
                
                if (date >= new Date().setHours(0,0,0,0)) {
                    dayEl.onclick = () => selectAdminDate(dateStr, dayEl);
                }
                
                if (selectedAdminDate === dateStr) {
                    dayEl.classList.add('selected');
                }
                
                grid.appendChild(dayEl);
            }
            
            updateUpcomingEvents();
        }

        function changeAdminMonth(delta) {
            currentAdminDate.setMonth(currentAdminDate.getMonth() + delta);
            renderAdminCalendar();
        }

        function selectAdminDate(dateStr, element) {
            selectedAdminDate = dateStr;
            document.querySelectorAll('.calendar-day.selected').forEach(el => el.classList.remove('selected'));
            element.classList.add('selected');
            
            const isBlocked = config.blockedDates.includes(dateStr);
            const booking = config.bookings.find(b => b.date === dateStr);
            
            document.getElementById('selected-date-info').innerHTML = `
                <p class="text-xl font-bold text-yellow-400">${new Date(dateStr).toLocaleDateString('es-ES', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}</p>
            `;
            
            document.getElementById('date-actions').classList.remove('hidden');
            document.getElementById('date-status-text').textContent = isBlocked ? 'No Disponible' : 'Disponible';
            document.getElementById('date-toggle').classList.toggle('active', !isBlocked);
            
            const bookingDetails = document.getElementById('booking-details');
            if (booking) {
                bookingDetails.classList.remove('hidden');
                document.getElementById('booking-info').innerHTML = `
                    <p><strong>Cliente:</strong> ${booking.name}</p>
                    <p><strong>Tipo:</strong> ${booking.eventType}</p>
                    <p><strong>Total:</strong> ${booking.totalPrice}</p>
                    <p><strong>Tel:</strong> ${booking.phone}</p>
                `;
            } else {
                bookingDetails.classList.add('hidden');
            }
        }

        function toggleDateStatus() {
            document.getElementById('date-toggle').classList.toggle('active');
            const isNowActive = document.getElementById('date-toggle').classList.contains('active');
            document.getElementById('date-status-text').textContent = isNowActive ? 'Disponible' : 'No Disponible';
        }

        function saveDateStatus() {
            if (!selectedAdminDate) return;
            
            const isAvailable = document.getElementById('date-toggle').classList.contains('active');
            const index = config.blockedDates.indexOf(selectedAdminDate);
            
            if (isAvailable && index > -1) {
                config.blockedDates.splice(index, 1);
            } else if (!isAvailable && index === -1) {
                config.blockedDates.push(selectedAdminDate);
            }
            
            saveConfig();
            renderAdminCalendar();
            updateStats();
            alert('Estado de fecha actualizado');
        }

        function updateUpcomingEvents() {
            const upcoming = config.bookings
                .filter(b => new Date(b.date) >= new Date())
                .sort((a, b) => new Date(a.date) - new Date(b.date))
                .slice(0, 10);
            
            document.getElementById('upcoming-events').innerHTML = upcoming.length ? upcoming.map(b => `
                <div class="flex justify-between items-center p-3 bg-black/30 rounded-lg border border-yellow-500/10">
                    <div>
                        <div class="font-semibold text-white">${new Date(b.date).toLocaleDateString('es-ES')}</div>
                        <div class="text-sm text-gray-400">${b.eventType} - ${b.name}</div>
                    </div>
                    <span class="text-yellow-400 font-bold">${b.totalPrice}</span>
                </div>
            `).join('') : '<p class="text-gray-500 text-center">No hay eventos próximos</p>';
        }

        // ==================== RESERVAS ====================

        function loadBookings() {
            const tbody = document.getElementById('bookings-table');
            const sorted = config.bookings.sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));
            
            document.getElementById('booking-count').textContent = sorted.length;
            
            tbody.innerHTML = sorted.map(b => `
                <tr class="border-b border-gray-800 hover:bg-white/5">
                    <td class="py-3">${new Date(b.date).toLocaleDateString('es-ES')}</td>
                    <td class="py-3">
                        <div class="font-semibold">${b.name}</div>
                        <div class="text-xs text-gray-500">${b.phone}</div>
                    </td>
                    <td class="py-3">
                        <span class="px-2 py-1 rounded bg-yellow-500/10 text-yellow-400 text-xs">${b.eventType}</span>
                    </td>
                    <td class="py-3 font-bold text-green-400">${b.totalPrice}</td>
                    <td class="py-3">
                        <span class="px-2 py-1 rounded bg-green-500/20 text-green-400 text-xs">Confirmado</span>
                    </td>
                    <td class="py-3">
                        <button onclick="viewBooking('${b.timestamp}')" class="text-yellow-400 hover:text-white mr-2">
                            <i class="fas fa-eye"></i>
                        </button>
                        <button onclick="deleteBooking('${b.timestamp}')" class="text-red-400 hover:text-red-300">
                            <i class="fas fa-trash"></i>
                        </button>
                    </td>
                </tr>
            `).join('');
        }

        function viewBooking(timestamp) {
            const booking = config.bookings.find(b => b.timestamp === timestamp);
            if (!booking) return;
            
            alert(`
RESERVA DETALLADA

Cliente: ${booking.name}
Teléfono: ${booking.phone}
Email: ${booking.email}

Evento: ${booking.eventType}
Fecha: ${booking.date}
Invitados: ${booking.guests}
Ambiente: ${booking.vibe}

Extras: ${booking.extras?.join(', ') || 'Ninguno'}
Total: ${booking.totalPrice}

Playlist/Música:
${booking.playlist || 'No especificado'}

Fecha de registro: ${new Date(booking.timestamp).toLocaleString('es-ES')}
            `);
        }

        function deleteBooking(timestamp) {
            if (!confirm('¿Eliminar esta reserva permanentemente?')) return;
            config.bookings = config.bookings.filter(b => b.timestamp !== timestamp);
            saveConfig();
            loadBookings();
            updateStats();
        }

        function filterBookings(search) {
            const rows = document.querySelectorAll('#bookings-table tr');
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(search.toLowerCase()) ? '' : 'none';
            });
        }

        function exportBookings() {
            const csv = [
                ['Fecha', 'Cliente', 'Teléfono', 'Email', 'Tipo Evento', 'Invitados', 'Total', 'Extras', 'Playlist'],
                ...config.bookings.map(b => [
                    b.date, b.name, b.phone, b.email, b.eventType, b.guests, b.totalPrice, 
                    b.extras?.join('; '), b.playlist
                ])
            ].map(row => row.join(',')).join('\n');
            
            const blob = new Blob([csv], { type: 'text/csv' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `reservas_${new Date().toISOString().split('T')[0]}.csv`;
            a.click();
        }

        // ==================== GALERÍA ====================

        function renderAdminGallery() {
            const grid = document.getElementById('gallery-grid');
            if (!grid) return;
            
            grid.innerHTML = config.gallery.map((img, index) => `
                <div class="gallery-item">
                    <img src="${img}" alt="Imagen ${index + 1}">
                    <button class="delete-btn" onclick="deleteImage(${index})">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            `).join('');
        }

        function renderPublicGallery() {
            const grid = document.getElementById('public-gallery-grid');
            if (!grid) return;
            
            if (config.gallery.length === 0) {
                grid.innerHTML = '<p class="text-gray-500 text-center col-span-full">No hay imágenes en la galería</p>';
                return;
            }
            
            grid.innerHTML = config.gallery.map((img, index) => `
                <div class="gallery-item">
                    <img src="${img}" alt="Imagen ${index + 1}">
                </div>
            `).join('');
        }

        function handleImageUpload(input) {
            const file = input.files[0];
            if (!file) return;
            
            if (file.size > 2 * 1024 * 1024) {
                alert('La imagen es muy grande. Máximo 2MB.');
                return;
            }
            
            const reader = new FileReader();
            reader.onload = function(e) {
                config.gallery.push(e.target.result);
                renderAdminGallery();
                input.value = '';
            };
            reader.readAsDataURL(file);
        }

        function deleteImage(index) {
            if (!confirm('¿Eliminar esta imagen?')) return;
            config.gallery.splice(index, 1);
            renderAdminGallery();
        }

        function saveGallery() {
            saveConfig();
            alert('Galería guardada correctamente');
        }

        // ==================== CONFIGURACIÓN ====================

        function changePassword() {
            const newPass = document.getElementById('new-password').value;
            const confirm = document.getElementById('confirm-password').value;
            
            if (!newPass || newPass !== confirm) {
                alert('Las contraseñas no coinciden');
                return;
            }
            
            config.password = newPass;
            saveConfig();
            alert('Contraseña actualizada');
            document.getElementById('new-password').value = '';
            document.getElementById('confirm-password').value = '';
        }

        function clearAllData() {
            if (!confirm('¿ESTÁS SEGURO? Se borrarán TODAS las reservas permanentemente')) return;
            if (!confirm('Doble confirmación: ¿Realmente deseas borrar todo?')) return;
            
            config.bookings = [];
            saveConfig();
            loadBookings();
            updateStats();
            alert('Todas las reservas han sido eliminadas');
        }

        function clearGallery() {
            if (!confirm('¿Eliminar todas las imágenes de la galería?')) return;
            config.gallery = [];
            saveConfig();
            renderAdminGallery();
            alert('Galería limpiada');
        }

        // ==================== PREVIEW Y EXPORT ====================

        function previewSite() {
            document.getElementById('admin-mode').classList.add('hidden');
            document.getElementById('public-site').classList.remove('hidden');
            
            // Actualizar contenido en preview
            document.querySelectorAll('.editable').forEach(el => {
                const field = el.dataset.field;
                if (config.content[field]) el.textContent = config.content[field];
            });
            
            // Actualizar teléfono
            document.getElementById('display-phone').textContent = config.content.phone;
            document.getElementById('public-phone-link').href = `tel:${config.content.phone}`;
            document.getElementById('public-whatsapp-link').href = `https://wa.me/52${config.content.phone}`;
            
            // Actualizar Facebook
            const fbLink = document.getElementById('public-facebook-link');
            if (fbLink && config.content.facebook) {
                fbLink.href = config.content.facebook;
            }
            
            // Cargar extras en formulario público
            const extrasContainer = document.getElementById('public-extras-list');
            extrasContainer.innerHTML = config.extras.filter(e => e.active).map(extra => `
                <label class="flex items-center gap-3 p-3 rounded-lg border border-yellow-600/20 cursor-pointer hover:border-yellow-500/50">
                    <input type="checkbox" class="checkbox-gold" value="${extra.id}" onchange="updatePublicPrice()" data-price="${extra.price}">
                    <div class="flex-1">
                        <div class="text-white font-semibold text-sm">${extra.name}</div>
                        <div class="text-gray-500 text-xs">${extra.description}</div>
                    </div>
                    <span class="text-yellow-400 font-bold">+$${extra.price.toLocaleString()}</span>
                </label>
            `).join('');
            
            renderPublicCalendar();
            renderPublicGallery();
        }

        function exportData() {
            const dataStr = JSON.stringify(config, null, 2);
            const blob = new Blob([dataStr], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `backup_sve_${new Date().toISOString().split('T')[0]}.json`;
            a.click();
        }

        // ==================== FUNCIONALIDAD PÚBLICA ====================

        function renderPublicCalendar() {
            const year = currentPublicDate.getFullYear();
            const month = currentPublicDate.getMonth();
            const firstDay = new Date(year, month, 1).getDay();
            const daysInMonth = new Date(year, month + 1, 0).getDate();
            
            document.getElementById('public-current-month').textContent = 
                new Date(year, month).toLocaleDateString('es-ES', { month: 'long', year: 'numeric' });
            
            const grid = document.getElementById('public-calendar-grid');
            grid.innerHTML = '';
            
            for (let i = 0; i < firstDay; i++) grid.appendChild(document.createElement('div'));
            
            for (let day = 1; day <= daysInMonth; day++) {
                const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
                const date = new Date(year, month, day);
                const isBlocked = config.blockedDates.includes(dateStr);
                const isPast = date < new Date().setHours(0,0,0,0);
                
                const dayEl = document.createElement('div');
                dayEl.className = `calendar-day ${isBlocked || isPast ? 'disabled' : ''}`;
                dayEl.textContent = day;
                
                if (!isBlocked && !isPast) {
                    dayEl.onclick = () => selectPublicDate(dateStr, dayEl);
                }
                
                grid.appendChild(dayEl);
            }
        }

        function changePublicMonth(delta) {
            currentPublicDate.setMonth(currentPublicDate.getMonth() + delta);
            renderPublicCalendar();
        }

        function selectPublicDate(dateStr, element) {
            document.getElementById('public-selected-date').value = dateStr;
            document.getElementById('public-date-display').textContent = 
                `Seleccionado: ${new Date(dateStr).toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long' })}`;
            
            document.querySelectorAll('#public-calendar-grid .calendar-day.selected').forEach(el => el.classList.remove('selected'));
            element.classList.add('selected');
        }

        function updatePublicPrice() {
            const guests = document.getElementById('public-guests').value;
            let total = config.prices[guests] || 0;
            
            document.querySelectorAll('#public-extras-list input:checked').forEach(cb => {
                total += parseInt(cb.dataset.price) || 0;
            });
            
            document.getElementById('public-total-price').textContent = '$' + total.toLocaleString();
        }

        function handlePublicBooking(e) {
            e.preventDefault();
            
            const booking = {
                eventType: document.getElementById('public-event-type').value,
                guests: document.getElementById('public-guests').value,
                date: document.getElementById('public-selected-date').value,
                vibe: document.querySelector('input[name="public-vibe"]:checked')?.value,
                customVibe: document.getElementById('public-custom-vibe').value,
                playlist: document.getElementById('public-playlist').value,
                extras: Array.from(document.querySelectorAll('#public-extras-list input:checked')).map(cb => cb.value),
                name: document.getElementById('public-name').value,
                phone: document.getElementById('public-phone').value,
                email: document.getElementById('public-email').value,
                totalPrice: document.getElementById('public-total-price').textContent,
                timestamp: new Date().toISOString()
            };
            
            // Guardar
            config.bookings.push(booking);
            
            // Bloquear fecha automáticamente
            if (!config.blockedDates.includes(booking.date)) {
                config.blockedDates.push(booking.date);
            }
            
            saveConfig();
            updateStats();
            
            // Enviar a WhatsApp
            const msg = `¡Nueva reserva!%0A%0ACliente: ${booking.name}%0ATel: ${booking.phone}%0AFecha: ${booking.date}%0ATotal: ${booking.totalPrice}`;
            window.open(`https://wa.me/52${config.content.phone}?text=${msg}`, '_blank');
            
            alert('¡Reserva enviada! Te contactaremos pronto.');
            e.target.reset();
            renderPublicCalendar();
        }

        // ==================== UTILIDADES ====================

        function saveConfig() {
            localStorage.setItem('sve_config', JSON.stringify(config));
            const lastUpdateEl = document.getElementById('last-update');
            if (lastUpdateEl) {
                lastUpdateEl.textContent = new Date().toLocaleString('es-ES');
            }
        }

        function updateStats() {
            const thisMonth = new Date().toISOString().slice(0, 7); // YYYY-MM
            const monthBookings = config.bookings.filter(b => b.date.startsWith(thisMonth));
            const revenue = monthBookings.reduce((sum, b) => sum + (parseInt(b.totalPrice?.replace(/[^0-9]/g, '')) || 0), 0);
            
            const monthBookingsEl = document.getElementById('month-bookings');
            const monthRevenueEl = document.getElementById('month-revenue');
            const blockedDatesEl = document.getElementById('blocked-dates-count');
            const bookingCountEl = document.getElementById('booking-count');
            
            if (monthBookingsEl) monthBookingsEl.textContent = monthBookings.length;
            if (monthRevenueEl) monthRevenueEl.textContent = '$' + revenue.toLocaleString();
            if (blockedDatesEl) blockedDatesEl.textContent = config.blockedDates.length;
            if (bookingCountEl) bookingCountEl.textContent = config.bookings.length;
            
            // Calcular uso de storage
            const totalStorageEl = document.getElementById('total-storage');
            if (totalStorageEl) {
                const bytes = new Blob([JSON.stringify(config)]).size;
                totalStorageEl.textContent = (bytes / 1024).toFixed(2) + ' KB';
            }
        }

        // ==================== EDICIÓN INLINE (BONUS) ====================

        function editSection(section) {
            // Implementación básica de edición inline
            const modal = document.getElementById('inline-edit-modal');
            const content = document.getElementById('inline-edit-content');
            
            if (section === 'hero') {
                content.innerHTML = `
                    <div class="space-y-4">
                        <div>
                            <label class="text-sm text-gray-400">Título Principal</label>
                            <input type="text" id="edit-hero-title" class="input-premium w-full px-4 py-2 rounded-lg mt-1" value="${config.content.heroTitle}">
                        </div>
                        <div>
                            <label class="text-sm text-gray-400">Subtítulo</label>
                            <input type="text" id="edit-hero-subtitle" class="input-premium w-full px-4 py-2 rounded-lg mt-1" value="${config.content.heroSubtitle}">
                        </div>
                    </div>
                `;
            }
            
            modal.classList.remove('hidden');
        }

        function saveInlineEdit() {
            config.content.heroTitle = document.getElementById('edit-hero-title')?.value || config.content.heroTitle;
            config.content.heroSubtitle = document.getElementById('edit-hero-subtitle')?.value || config.content.heroSubtitle;
            saveConfig();
            closeInlineEdit();
            previewSite(); // Recargar preview
        }

        function closeInlineEdit() {
            document.getElementById('inline-edit-modal').classList.add('hidden');
        }

        // Inicializar al cargar
        init();
    </script>
</body>
</html>
