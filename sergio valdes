<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sergio Valdés Enríquez | Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --gold-primary: #D4AF37;
            --gold-light: #F4E4BC;
            --gold-dark: #AA8C2C;
            --black-primary: #0a0a0a;
            --black-secondary: #1a1a1a;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: var(--black-primary);
            color: #ffffff;
        }

        h1, h2, h3, .elegant-font {
            font-family: 'Cinzel', serif;
        }

        .gold-gradient {
            background: linear-gradient(135deg, var(--gold-primary) 0%, var(--gold-light) 50%, var(--gold-dark) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .gold-bg-gradient {
            background: linear-gradient(135deg, var(--gold-primary) 0%, var(--gold-light) 50%, var(--gold-dark) 100%);
        }

        .input-premium {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(212, 175, 55, 0.3);
            color: #fff;
            transition: all 0.3s ease;
        }

        .input-premium:focus {
            outline: none;
            border-color: var(--gold-primary);
            box-shadow: 0 0 20px rgba(212, 175, 55, 0.2);
        }

        .btn-premium {
            background: linear-gradient(135deg, rgba(212, 175, 55, 0.1) 0%, rgba(212, 175, 55, 0.05) 100%);
            border: 2px solid var(--gold-primary);
            color: var(--gold-primary);
            transition: all 0.4s ease;
        }

        .btn-premium:hover {
            background: linear-gradient(135deg, var(--gold-primary) 0%, var(--gold-light) 100%);
            color: var(--black-primary);
        }

        .admin-panel {
            background: rgba(26, 26, 26, 0.95);
            border: 1px solid rgba(212, 175, 55, 0.3);
        }

        .tab-active {
            background: var(--gold-primary);
            color: var(--black-primary);
        }

        .calendar-day {
            aspect-ratio: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
            border-radius: 8px;
            font-size: 0.9rem;
        }

        .calendar-day:hover:not(.disabled) {
            background: rgba(212, 175, 55, 0.2);
            color: var(--gold-primary);
        }

        .calendar-day.selected {
            background: var(--gold-primary);
            color: var(--black-primary);
            font-weight: bold;
        }

        .calendar-day.disabled {
            color: rgba(255, 255, 255, 0.2);
            cursor: not-allowed;
            text-decoration: line-through;
        }

        .calendar-day.today {
            border: 2px solid var(--gold-primary);
        }

        .checkbox-gold {
            appearance: none;
            width: 20px;
            height: 20px;
            border: 2px solid rgba(212, 175, 55, 0.5);
            border-radius: 4px;
            cursor: pointer;
            position: relative;
            transition: all 0.3s ease;
        }

        .checkbox-gold:checked {
            background: var(--gold-primary);
            border-color: var(--gold-primary);
        }

        .checkbox-gold:checked::after {
            content: '✓';
            position: absolute;
            color: var(--black-primary);
            font-size: 14px;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-weight: bold;
        }

        /* Toggle Switch */
        .toggle-switch {
            position: relative;
            width: 60px;
            height: 30px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 30px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .toggle-switch.active {
            background: var(--gold-primary);
        }

        .toggle-switch::after {
            content: '';
            position: absolute;
            width: 26px;
            height: 26px;
            background: white;
            border-radius: 50%;
            top: 2px;
            left: 2px;
            transition: all 0.3s;
        }

        .toggle-switch.active::after {
            left: 32px;
        }

        /* Preview Mode */
        .preview-mode {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: var(--black-primary);
            z-index: 1000;
            overflow-y: auto;
        }

        .edit-mode-badge {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: var(--gold-primary);
            color: var(--black-primary);
            padding: 12px 24px;
            border-radius: 30px;
            font-weight: bold;
            cursor: pointer;
            z-index: 999;
            box-shadow: 0 4px 20px rgba(212, 175, 55, 0.4);
        }

        .section-editable {
            position: relative;
            border: 2px dashed transparent;
            transition: all 0.3s;
        }

        .section-editable:hover {
            border-color: rgba(212, 175, 55, 0.5);
            background: rgba(212, 175, 55, 0.05);
        }

        .edit-btn {
            position: absolute;
            top: 10px;
            right: 10px;
            background: var(--gold-primary);
            color: var(--black-primary);
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
            cursor: pointer;
            opacity: 0;
            transition: all 0.3s;
            z-index: 10;
        }

        .section-editable:hover .edit-btn {
            opacity: 1;
        }

        /* Modal de edición inline */
        .inline-edit-modal {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: var(--black-secondary);
            border: 2px solid var(--gold-primary);
            border-radius: 20px;
            padding: 30px;
            z-index: 1001;
            min-width: 500px;
            max-width: 90vw;
            max-height: 80vh;
            overflow-y: auto;
        }

        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.8);
            z-index: 1000;
        }

        .hidden { display: none !important; }

        /* Admin access hidden */
        .admin-access {
            position: fixed;
            bottom: 10px;
            right: 10px;
            font-size: 10px;
            color: rgba(255,255,255,0.2);
            cursor: pointer;
            z-index: 100;
            padding: 5px;
            user-select: none;
        }
        .admin-access:hover {
            color: rgba(255,255,255,0.5);
        }

        /* Galería */
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 1rem;
        }
        .gallery-item {
            position: relative;
            aspect-ratio: 1;
            border-radius: 12px;
            overflow: hidden;
            border: 2px solid rgba(212, 175, 55, 0.3);
        }
        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .gallery-item .delete-btn {
            position: absolute;
            top: 5px;
            right: 5px;
            background: rgba(255,0,0,0.8);
            color: white;
            border: none;
            border-radius: 50%;
            width: 30px;
            height: 30px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>
</head>
<body>

    <!-- MODO EDICIÓN: Panel de Administración (OCULTO INICIALMENTE) -->
    <div id="admin-mode" class="hidden">
        <!-- Login Screen -->
        <div id="login-screen" class="min-h-screen flex items-center justify-center p-4">
            <div class="glass-effect rounded-3xl p-8 max-w-md w-full border border-yellow-500/30 text-center">
                <div class="w-20 h-20 mx-auto mb-6 rounded-full gold-bg-gradient flex items-center justify-center">
                    <i class="fas fa-lock text-3xl text-black"></i>
                </div>
                <h1 class="text-3xl font-bold mb-2 gold-gradient elegant-font">Panel de Administración</h1>
                <p class="text-gray-400 mb-6">Sergio Valdés Enríquez</p>
                
                <div class="space-y-4">
                    <input type="password" id="admin-password" placeholder="Contraseña de administrador" 
                           class="input-premium w-full px-4 py-3 rounded-xl text-center">
                    <button onclick="login()" class="w-full btn-premium py-3 rounded-xl font-bold">
                        <i class="fas fa-sign-in-alt mr-2"></i>Acceder al Panel
                    </button>
                    <button onclick="backToPublic()" class="w-full px-4 py-2 text-gray-500 hover:text-white text-sm">
                        ← Volver a la página pública
                    </button>
                </div>
            </div>
        </div>

        <!-- Admin Dashboard -->
        <div id="admin-dashboard" class="hidden min-h-screen">
            <!-- Header Admin -->
            <div class="bg-black/80 border-b border-yellow-500/20 p-4 sticky top-0 z-50">
                <div class="max-w-7xl mx-auto flex justify-between items-center">
                    <div class="flex items-center gap-4">
                        <h1 class="text-2xl font-bold gold-gradient elegant-font">Panel de Control</h1>
                        <span class="px-3 py-1 rounded-full bg-green-500/20 text-green-400 text-xs">● En línea</span>
                    </div>
                    <div class="flex gap-3">
                        <button onclick="previewSite()" class="px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors">
                            <i class="fas fa-eye mr-2"></i>Ver Página
                        </button>
                        <button onclick="exportData()" class="px-4 py-2 rounded-lg bg-gray-700 hover:bg-gray-600 text-white text-sm font-semibold transition-colors">
                            <i class="fas fa-download mr-2"></i>Exportar Datos
                        </button>
                        <button onclick="logout()" class="px-4 py-2 rounded-lg border border-red-500 text-red-400 hover:bg-red-500/10 text-sm font-semibold transition-colors">
                            <i class="fas fa-sign-out-alt mr-2"></i>Salir
                        </button>
                    </div>
                </div>
            </div>

            <div class="max-w-7xl mx-auto p-6 grid lg:grid-cols-4 gap-6">
                <!-- Sidebar -->
                <div class="lg:col-span-1 space-y-4">
                    <div class="admin-panel rounded-2xl p-4">
                        <h3 class="text-yellow-400 font-bold mb-4 text-sm uppercase tracking-wider">Menú</h3>
                        <nav class="space-y-2">
                            <button onclick="showTab('prices')" class="w-full text-left px-4 py-3 rounded-xl hover:bg-yellow-500/10 transition-colors tab-btn active" data-tab="prices">
                                <i class="fas fa-dollar-sign w-6"></i>Precios
                            </button>
                            <button onclick="showTab('extras')" class="w-full text-left px-4 py-3 rounded-xl hover:bg-yellow-500/10 transition-colors tab-btn" data-tab="extras">
                                <i class="fas fa-plus-circle w-6"></i>Servicios Extra
                            </button>
                            <button onclick="showTab('content')" class="w-full text-left px-4 py-3 rounded-xl hover:bg-yellow-500/10 transition-colors tab-btn" data-tab="content">
                                <i class="fas fa-edit w-6"></i>Textos y Contenido
                            </button>
                            <button onclick="showTab('calendar')" class="w-full text-left px-4 py-3 rounded-xl hover:bg-yellow-500/10 transition-colors tab-btn" data-tab="calendar">
                                <i class="fas fa-calendar-alt w-6"></i>Calendario
                            </button>
                            <button onclick="showTab('bookings')" class="w-full text-left px-4 py-3 rounded-xl hover:bg-yellow-500/10 transition-colors tab-btn" data-tab="bookings">
                                <i class="fas fa-book w-6"></i>Reservas <span id="booking-count" class="ml-auto bg-yellow-500 text-black px-2 py-0.5 rounded-full text-xs">0</span>
                            </button>
                            <button onclick="showTab('gallery')" class="w-full text-left px-4 py-3 rounded-xl hover:bg-yellow-500/10 transition-colors tab-btn" data-tab="gallery">
                                <i class="fas fa-images w-6"></i>Galería
                            </button>
                            <button onclick="showTab('settings')" class="w-full text-left px-4 py-3 rounded-xl hover:bg-yellow-500/10 transition-colors tab-btn" data-tab="settings">
                                <i class="fas fa-cog w-6"></i>Configuración
                            </button>
                        </nav>
                    </div>

                    <!-- Resumen Rápido -->
                    <div class="admin-panel rounded-2xl p-4">
                        <h3 class="text-yellow-400 font-bold mb-4 text-sm uppercase tracking-wider">Resumen</h3>
                        <div class="space-y-3 text-sm">
                            <div class="flex justify-between">
                                <span class="text-gray-400">Reservas este mes</span>
                                <span class="text-white font-bold" id="month-bookings">0</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-gray-400">Ingresos estimados</span>
                                <span class="text-green-400 font-bold" id="month-revenue">$0</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-gray-400">Fechas bloqueadas</span>
                                <span class="text-red-400 font-bold" id="blocked-dates-count">0</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Main Content -->
                <div class="lg:col-span-3">
                    <!-- TAB: Precios -->
                    <div id="tab-prices" class="tab-content">
                        <div class="admin-panel rounded-2xl p-6 mb-6">
                            <h2 class="text-2xl font-bold mb-6 gold-gradient">Configuración de Precios Base</h2>
                            
                            <div class="grid md:grid-cols-2 gap-6 mb-6">
                                <div>
                                    <label class="block text-yellow-400 text-sm font-semibold mb-2">1-50 invitados</label>
                                    <div class="relative">
                                        <span class="absolute left-4 top-3.5 text-gray-400">$</span>
                                        <input type="number" id="price-1-50" class="input-premium w-full pl-8 pr-4 py-3 rounded-xl" value="6000">
                                    </div>
                                </div>
                                <div>
                                    <label class="block text-yellow-400 text-sm font-semibold mb-2">51-100 invitados</label>
                                    <div class="relative">
                                        <span class="absolute left-4 top-3.5 text-gray-400">$</span>
                                        <input type="number" id="price-51-100" class="input-premium w-full pl-8 pr-4 py-3 rounded-xl" value="8000">
                                    </div>
                                </div>
                                <div>
                                    <label class="block text-yellow-400 text-sm font-semibold mb-2">101-200 invitados (Más popular)</label>
                                    <div class="relative">
                                        <span class="absolute left-4 top-3.5 text-gray-400">$</span>
                                        <input type="number" id="price-101-200" class="input-premium w-full pl-8 pr-4 py-3 rounded-xl" value="10000">
                                    </div>
                                </div>
                                <div>
                                    <label class="block text-yellow-400 text-sm font-semibold mb-2">201-300 invitados</label>
                                    <div class="relative">
                                        <span class="absolute left-4 top-3.5 text-gray-400">$</span>
                                        <input type="number" id="price-201-300" class="input-premium w-full pl-8 pr-4 py-3 rounded-xl" value="13000">
                                    </div>
                                </div>
                                <div class="md:col-span-2">
                                    <label class="block text-yellow-400 text-sm font-semibold mb-2">300+ invitados (Gran evento)</label>
                                    <div class="relative">
                                        <span class="absolute left-4 top-3.5 text-gray-400">$</span>
                                        <input type="number" id="price-300" class="input-premium w-full pl-8 pr-4 py-3 rounded-xl" value="16000">
                                    </div>
                                </div>
                            </div>

                            <div class="flex gap-4">
                                <button onclick="savePrices()" class="btn-premium px-6 py-3 rounded-xl font-bold">
                                    <i class="fas fa-save mr-2"></i>Guardar Precios
                                </button>
                                <button onclick="resetPrices()" class="px-6 py-3 rounded-xl border border-gray-600 text-gray-400 hover:text-white transition-colors">
                                    Restaurar Default
                                </button>
                            </div>
                        </div>

                        <!-- Vista Previa de Precios -->
                        <div class="admin-panel rounded-2xl p-6">
                            <h3 class="text-lg font-bold mb-4 text-white">Vista Previa</h3>
                            <div class="grid md:grid-cols-3 gap-4" id="price-preview">
                                <!-- Generado dinámicamente -->
                            </div>
                        </div>
                    </div>

                    <!-- TAB: Servicios Extra -->
                    <div id="tab-extras" class="tab-content hidden">
                        <div class="admin-panel rounded-2xl p-6">
                            <div class="flex justify-between items-center mb-6">
                                <h2 class="text-2xl font-bold gold-gradient">Servicios Adicionales</h2>
                                <button onclick="addNewExtra()" class="px-4 py-2 rounded-lg bg-green-600 hover:bg-green-700 text-white text-sm font-semibold">
                                    <i class="fas fa-plus mr-2"></i>Agregar Nuevo
                                </button>
                            </div>

                            <div id="extras-list" class="space-y-4">
                                <!-- Items generados dinámicamente -->
                            </div>

                            <div class="mt-6 pt-6 border-t border-gray-700">
                                <button onclick="saveExtras()" class="btn-premium px-6 py-3 rounded-xl font-bold w-full">
                                    <i class="fas fa-save mr-2"></i>Guardar Cambios
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- TAB: Contenido -->
                    <div id="tab-content" class="tab-content hidden">
                        <div class="admin-panel rounded-2xl p-6 mb-6">
                            <h2 class="text-2xl font-bold mb-6 gold-gradient">Editar Contenido de la Página</h2>
                            
                            <div class="space-y-6">
                                <div>
                                    <label class="block text-yellow-400 text-sm font-semibold mb-2">Título Principal (Hero)</label>
                                    <input type="text" id="content-hero-title" class="input-premium w-full px-4 py-3 rounded-xl" value="Transforma tu Evento">
                                </div>
                                
                                <div>
                                    <label class="block text-yellow-400 text-sm font-semibold mb-2">Subtítulo</label>
                                    <input type="text" id="content-hero-subtitle" class="input-premium w-full px-4 py-3 rounded-xl" value="en una Experiencia Inolvidable">
                                </div>

                                <div>
                                    <label class="block text-yellow-400 text-sm font-semibold mb-2">Descripción Principal</label>
                                    <textarea id="content-description" rows="3" class="input-premium w-full px-4 py-3 rounded-xl">Más de 500 eventos exitosos. La combinación perfecta de voz, música y animación que tu celebración merece.</textarea>
                                </div>

                                <div>
                                    <label class="block text-yellow-400 text-sm font-semibold mb-2">Número de WhatsApp</label>
                                    <input type="tel" id="content-phone" class="input-premium w-full px-4 py-3 rounded-xl" value="7228077264">
                                </div>

                                <div>
                                    <label class="block text-yellow-400 text-sm font-semibold mb-2">Mensaje de Urgencia</label>
                                    <input type="text" id="content-urgency" class="input-premium w-full px-4 py-3 rounded-xl" value="Solo quedan 4 fechas disponibles para diciembre 2026">
                                </div>

                                <div>
                                    <label class="block text-yellow-400 text-sm font-semibold mb-2">Página de Facebook</label>
                                    <input type="url" id="content-facebook" class="input-premium w-full px-4 py-3 rounded-xl" value="https://www.facebook.com/share/1C92LXi5wP/">
                                </div>
                            </div>

                            <div class="mt-6">
                                <button onclick="saveContent()" class="btn-premium px-6 py-3 rounded-xl font-bold">
                                    <i class="fas fa-save mr-2"></i>Guardar Contenido
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- TAB: Calendario -->
                    <div id="tab-calendar" class="tab-content hidden">
                        <div class="admin-panel rounded-2xl p-6">
                            <h2 class="text-2xl font-bold mb-6 gold-gradient">Gestión de Calendario</h2>
                            
                            <div class="grid lg:grid-cols-2 gap-6">
                                <!-- Calendario -->
                                <div>
                                    <div class="flex justify-between items-center mb-4">
                                        <button onclick="changeAdminMonth(-1)" class="text-yellow-500 hover:text-white p-2">
                                            <i class="fas fa-chevron-left"></i>
                                        </button>
                                        <h3 id="admin-current-month" class="text-xl font-bold"></h3>
                                        <button onclick="changeAdminMonth(1)" class="text-yellow-500 hover:text-white p-2">
                                            <i class="fas fa-chevron-right"></i>
                                        </button>
                                    </div>
                                    <div class="grid grid-cols-7 gap-2 mb-2 text-center text-sm text-gray-400">
                                        <div>Dom</div><div>Lun</div><div>Mar</div><div>Mié</div><div>Jue</div><div>Vie</div><div>Sáb</div>
                                    </div>
                                    <div id="admin-calendar-grid" class="grid grid-cols-7 gap-2">
                                        <!-- Generado por JS -->
                                    </div>
                                </div>

                                <!-- Panel de Fecha Seleccionada -->
                                <div class="bg-black/30 rounded-xl p-4 border border-yellow-500/20">
                                    <h3 class="text-lg font-bold mb-4 text-white">Fecha Seleccionada</h3>
                                    <div id="selected-date-info" class="mb-4">
                                        <p class="text-gray-400">Selecciona una fecha en el calendario</p>
                                    </div>
                                    
                                    <div id="date-actions" class="space-y-3 hidden">
                                        <div class="flex items-center justify-between p-3 bg-black/50 rounded-lg">
                                            <span class="text-white">Estado:</span>
                                            <div class="flex items-center gap-3">
                                                <span class="text-sm text-gray-400" id="date-status-text">Disponible</span>
                                                <div class="toggle-switch" id="date-toggle" onclick="toggleDateStatus()"></div>
                                            </div>
                                        </div>
                                        
                                        <div id="booking-details" class="hidden space-y-3">
                                            <div class="p-3 bg-yellow-500/10 rounded-lg border border-yellow-500/30">
                                                <p class="text-yellow-400 font-semibold mb-2">Reserva Existente</p>
                                                <div id="booking-info" class="text-sm text-gray-300 space-y-1"></div>
                                            </div>
                                        </div>

                                        <button onclick="saveDateStatus()" class="w-full btn-premium py-3 rounded-lg font-semibold">
                                            Guardar Cambios
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <!-- Lista de Próximos Eventos -->
                            <div class="mt-6">
                                <h3 class="text-lg font-bold mb-4 text-white">Próximos Eventos Confirmados</h3>
                                <div id="upcoming-events" class="space-y-2 max-h-60 overflow-y-auto">
                                    <!-- Generado dinámicamente -->
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- TAB: Reservas -->
                    <div id="tab-bookings" class="tab-content hidden">
                        <div class="admin-panel rounded-2xl p-6">
                            <div class="flex justify-between items-center mb-6">
                                <h2 class="text-2xl font-bold gold-gradient">Todas las Reservas</h2>
